<main class="mx-auto flex min-h-screen w-full max-w-4xl flex-col justify-center px-6 py-12">
  <div class="rounded-3xl border border-stone-200 bg-white/90 p-8 shadow-sm">
    <div class="flex items-center justify-between gap-4">
      <p class="text-sm uppercase tracking-[0.3em] text-stone-500">Roll The Dice</p>
      <%= link_to "Rules", rules_path, class: "text-xs font-semibold uppercase tracking-[0.2em] text-stone-500 hover:text-stone-700" %>
    </div>
    <h1 class="mt-4 text-4xl font-semibold text-stone-900">Host a new game</h1>
    <p class="mt-3 max-w-xl text-base text-stone-600">
      Start a room, share the join link, and keep the energy in the room while you drive the scores.
    </p>

    <div class="mt-8">
      <%= button_to "Create Game", games_path, method: :post, class: "inline-flex items-center rounded-full bg-amber-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-amber-700" %>
    </div>
  </div>
</main>
