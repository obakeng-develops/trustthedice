<div class="flex items-center justify-between">
  <h2 class="text-lg font-semibold text-stone-900">Team Scores</h2>
  <span class="text-xs text-stone-500">Live updates</span>
</div>

<% teams = game.teams.order(score: :desc, name: :asc) %>
<% if teams.any? %>
  <ol class="mt-4 grid gap-3">
    <% teams.each_with_index do |team, index| %>
      <li class="flex items-center justify-between rounded-2xl border border-stone-100 bg-stone-50 px-4 py-3">
        <div class="flex items-center gap-3">
          <span class="text-xs text-stone-500">#<%= index + 1 %></span>
          <strong class="text-base text-stone-900"><%= team.name %></strong>
        </div>
        <span class="text-sm font-semibold text-stone-700"><%= team.score %> pts</span>
      </li>
    <% end %>
  </ol>
<% else %>
  <p class="mt-3 text-sm text-stone-500">No teams yet.</p>
<% end %>
