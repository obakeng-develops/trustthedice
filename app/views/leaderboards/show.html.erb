<main class="mx-auto w-full max-w-4xl px-6 py-10">
  <%= turbo_stream_from "game_#{@game.id}" %>
  <header class="flex flex-col gap-2">
    <p class="text-xs uppercase tracking-[0.3em] text-stone-500">Leaderboard</p>
    <div class="flex flex-wrap items-end justify-between gap-3">
      <h1 class="text-3xl font-semibold text-stone-900">Roll The Dice</h1>
      <span class="rounded-full border border-stone-200 bg-white px-3 py-1 text-xs text-stone-600">
        Game <%= @game.id %>
      </span>
    </div>
  </header>

  <section class="mt-6 rounded-3xl border border-stone-200 bg-white p-6 shadow-sm" id="leaderboard-state">
    <%= render "leaderboard_state", game: @game %>
  </section>
</main>
